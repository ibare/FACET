{
  "name": "facet",
  "version": "0.0.0",
  "private": true,
  "description": "Framework for Abstraction and Concept Exploration through Translation",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @facet/playground dev",
    "build": "pnpm --filter @facet/playground build",
    "build:bundle": "pnpm --filter @facet/host-tiptap-bundle build",
    "build:bundle:analyze": "pnpm --filter @facet/host-tiptap-bundle build:analyze",
    "preview": "pnpm --filter @facet/playground preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@facet/algorithm-bubblesort": "workspace:*",
    "@facet/algorithm-quicksort": "workspace:*",
    "@facet/core": "workspace:*",
    "@facet/host-tiptap": "workspace:*",
    "@facet/ir-interpreter": "workspace:*",
    "@facet/transpiler-cpp": "workspace:*",
    "@facet/transpiler-csharp": "workspace:*",
    "@facet/transpiler-java": "workspace:*",
    "@facet/transpiler-javascript": "workspace:*",
    "@facet/transpiler-python": "workspace:*",
    "@facet/transpiler-typescript": "workspace:*",
    "@types/node": "^22.9.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
